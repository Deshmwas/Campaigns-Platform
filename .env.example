# Database
DATABASE_URL="mysql://root:password@localhost:3306/campaigns_db"

# Server
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-secret-key-change-in-production

# SMTP Configuration (for outbound emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME="Campaigns System"

# Application URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:5000

# Email Tracking Configuration
# The domain used for click and open tracking. 
# In production, this should be your public API URL (e.g., https://api.yourdomain.com)
# If left blank, it falls back to API_URL or the environment's external URL.
TRACKING_DOMAIN=

# Rate Limiting (per minute)
EMAIL_RATE_LIMIT=100
SMS_RATE_LIMIT=50

# SMS Gateway Configuration
# Options: logger (default), http (e.g. Africa's Talking), smpp (not implemented)
SMS_GATEWAY=logger
SMS_API_URL=https://api.africastalking.com/version1/messaging
SMS_API_KEY=your_africastalking_api_key
SMS_USERNAME=your_africastalking_username

# Cloudinary (Image Storage)
CLOUDINARY_CLOUD_NAME=dvfxfhsn8
CLOUDINARY_API_KEY=441763776177718
CLOUDINARY_API_SECRET=mNv7L46CfMCXA-lcFDyu4RX6Jik

# Encryption Key (for SMTP password encryption; falls back to JWT_SECRET if not set)
# ENCRYPTION_KEY=your-strong-random-encryption-key
